{
  "name": "text-overlay",
  "description": "Generate a text animation clip (title, intro, outro)",
  "template": "text-overlay",
  "defaultDuration": 5,
  "parameters": {
    "type": "object",
    "required": ["text"],
    "properties": {
      "text": { "type": "string", "description": "Text to display" },
      "fontSize": { "type": "number", "default": 80 },
      "color": { "type": "string", "default": "#ffffff" },
      "backgroundColor": { "type": "string", "default": "#1a1a2e" },
      "durationSeconds": { "type": "number", "default": 5 },
      "output": { "type": "string", "default": "out/text-overlay.mp4" }
    }
  }
}
